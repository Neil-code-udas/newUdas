<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boshz.udas.department.mapper.DepartmentMapper">

    <resultMap type="com.boshz.udas.department.entity.Department" id="DepartmentMap">
        <result property="id" column="id" jdbcType="INTEGER"/>
        <result property="orgCode" column="org_code" jdbcType="VARCHAR"/>
        <result property="orgName" column="org_name" jdbcType="VARCHAR"/>
    </resultMap>

    <!--查询单个-->
    <select id="selectById" resultMap="DepartmentMap">
        select id,
               org_code,
               org_name
        from tb_department
        where id = #{id}
    </select>

    <select id="selectByOrgName" resultMap="DepartmentMap">
        select id,
               org_code,
               org_name
        from tb_department
        where addr = #{orgName}
    </select>

    <!--查询指定行数据（适配 offset/pageSize）-->
    <select id="queryAllByLimit" resultMap="DepartmentMap">
        select
        id, org_code, org_name
        from tb_department
        <where>
            <if test="query.id != null">
                and id = #{query.id}
            </if>
            <if test="query.orgCode != null and query.orgCode != ''">
                and org_code = #{query.orgCode}
            </if>
            <if test="query.orgName != null and query.orgName != ''">
                and org_name = #{query.orgName}
            </if>
        </where>
        <if test="offset != null">
            limit #{offset}, #{pageSize}
        </if>
    </select>

    <!--统计总行数-->
    <select id="selectCount" resultType="java.lang.Long">
        select count(1)
        from tb_department
        <where>
            <if test="query.id != null">
                and id = #{query.id}
            </if>
            <if test="query.orgCode != null and query.orgCode != ''">
                and org_code = #{query.orgCode}
            </if>
            <if test="query.orgName != null and query.orgName != ''">
                and org_name = #{query.orgName}
            </if>
        </where>
    </select>

    <!--新增所有列-->
    <insert id="insert" keyProperty="id" useGeneratedKeys="true">
        insert into tb_department(org_code, org_name)
        values (#{orgCode}, #{orgName})
    </insert>

    <insert id="insertBatch" keyProperty="id" useGeneratedKeys="true">
        insert into tb_department(org_code, org_name)
        values
        <foreach collection="entities" item="entity" separator=",">
            (#{entity.orgCode}, #{entity.orgName})
        </foreach>
    </insert>

    <insert id="insertOrUpdateBatch" keyProperty="id" useGeneratedKeys="true">
        insert into tb_department(org_code, org_name)
        values
        <foreach collection="entities" item="entity" separator=",">
            (#{entity.orgCode}, #{entity.orgName})
        </foreach>
        on duplicate key update
        org_code = values(org_code),
        org_name = values(org_name)
    </insert>

    <!--通过主键修改数据-->
    <update id="update">
        update tb_department
        <set>
            <if test="orgCode != null and orgCode != ''">
                org_code = #{orgCode},
            </if>
            <if test="orgName != null and orgName != ''">
                org_name = #{orgName},
            </if>
        </set>
        where id = #{id}
    </update>

    <!--通过主键删除-->
    <delete id="deleteById">
        delete
        from tb_department
        where id = #{id}
    </delete>

</mapper>
